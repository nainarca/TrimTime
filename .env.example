# ============================================================
# TRIMTIME — Environment Variables Template
# Copy this file to .env and fill in your values
# ============================================================

# ── Application ──────────────────────────────────────────────
NODE_ENV=development
APP_PORT=3000
APP_URL=http://localhost:3000
# Comma-separated; include :4201 if you use apps/admin-dashboard (QueueCut admin UI)
FRONTEND_URL=http://localhost:4200,http://localhost:4201
MOBILE_URL=http://localhost:4300

# ── Database (PostgreSQL) ─────────────────────────────────────
DATABASE_URL="postgresql://trimtime_user:trimtime_pass@localhost:5432/trimtime_dev?schema=public"
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=trimtime_dev
DATABASE_USER=trimtime_user
DATABASE_PASSWORD=trimtime_pass

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT Authentication ────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production

# ── OTP Configuration ─────────────────────────────────────────
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=3
OTP_LENGTH=6
# Demo / pre-SMS: non-production only. Ignored when NODE_ENV=production.
# - Omit DEV_STATIC_OTP entirely (recommended for demos) → fixed code 123456, no SMS.
# - Add DEV_STATIC_OTP= with no value → random OTP each request (still echoed in API when not production).
# - DEV_STATIC_OTP=888888 → use that numeric code (min 4 digits).
# (Do not copy a blank "DEV_STATIC_OTP=" line if you want the 123456 default — that forces random OTP.)

# ── Twilio (SMS / OTP) ────────────────────────────────────────
# Go-live: set NODE_ENV=production, configure Twilio (or another provider), wire sending in AuthService — real OTP only.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ── Stripe (Billing) ──────────────────────────────────────────
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=your_webhook_secret

# ── Cloudinary (File Storage) ─────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Email (SMTP / SendGrid) ───────────────────────────────────
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
EMAIL_FROM=noreply@trimtime.app
EMAIL_FROM_NAME=TrimTime

# ── Queue Configuration ───────────────────────────────────────
QUEUE_NO_SHOW_TIMEOUT_MINS=10
QUEUE_REMINDER_POSITION=2
QUEUE_MAX_TICKET_NUMBER=999
QUEUE_DEFAULT_EWT_BUFFER_PERCENT=15

# ── BullMQ Job Queues ─────────────────────────────────────────
BULL_QUEUE_PREFIX=trimtime
BULL_CONCURRENCY=5

# ── Firebase (Push Notifications) ────────────────────────────
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_PRIVATE_KEY=your_private_key
FIREBASE_CLIENT_EMAIL=your_client_email

# ── GraphQL ───────────────────────────────────────────────────
GRAPHQL_PLAYGROUND=true
GRAPHQL_DEBUG=true
GRAPHQL_INTROSPECTION=true

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_PRETTY=true

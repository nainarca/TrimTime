{
  "name": "trimtime",
  "version": "0.0.1",
  "description": "TrimTime — QR-based smart queue management platform for barber shops",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "start:api": "nx serve api",
    "start:dashboard": "nx serve admin-dashboard",
    "start:mobile": "nx serve customer-mobile",
    "start:display": "nx serve queue-display",
    "build:api": "nx build api",
    "build:all": "nx run-many --target=build --all",
    "test": "nx run-many --target=test --all",
    "lint": "nx run-many --target=lint --all",
    "prisma:generate": "prisma generate --schema=prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "prisma:migrate:prod": "prisma migrate deploy --schema=prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=prisma/schema.prisma",
    "prisma:seed": "ts-node prisma/seed.ts",
    "prisma:reset": "prisma migrate reset --schema=prisma/schema.prisma",
    "codegen": "graphql-codegen --config libs/graphql-schema/codegen.yml",
    "codegen:watch": "graphql-codegen --config libs/graphql-schema/codegen.yml --watch",
    "docker:up": "docker-compose -f docker-compose.dev.yml up -d",
    "docker:down": "docker-compose -f docker-compose.dev.yml down",
    "docker:logs": "docker-compose -f docker-compose.dev.yml logs -f"
  },
